{
	"arrowParens": "always",
	"bracketSameLine": true,
	"objectWrap": "preserve",
	"bracketSpacing": true,
	"semi": true,
	"experimentalOperatorPosition": "start",
	"experimentalTernaries": true,
	"singleQuote": false,
	"jsxSingleQuote": true,
	"quoteProps": "consistent",
	"trailingComma": "none",
	"singleAttributePerLine": false,
	"htmlWhitespaceSensitivity": "css",
	"vueIndentScriptAndStyle": false,
	"proseWrap": "preserve",
	"endOfLine": "lf",
	"insertPragma": false,
	"printWidth": 84,
	"requirePragma": false,
	"tabWidth": 2,
	"useTabs": true,
	"embeddedLanguageFormatting": "auto"
}
